  },
  "dependencies": {
    "axios": "^1.17.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.2.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}