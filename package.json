{
  "name": "cyberMitra-ai",
  "version": "4.0.0",
  "description": "Real-time Scam Detection with Groq + Telegram + SQLite | Multilingual, Dark/Light Mode, History Search, CSV Export, Leaderboard, Scam Reporting",
  "main": "server.js",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node server.js",
